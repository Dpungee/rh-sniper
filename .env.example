# Optional: fast, non-rate-limited RPC + real-time WebSocket event streaming.
# Get a free key at https://dashboard.alchemy.com (create a Robinhood Chain app).
ALCHEMY_KEY=

# Or point directly at any provider (these override ALCHEMY_KEY and the public RPC):
# RH_RPC_HTTP=https://robinhood-mainnet.g.alchemy.com/v2/YOUR_KEY
# RH_RPC_WSS=wss://robinhood-mainnet.g.alchemy.com/v2/YOUR_KEY

# Optional: keystore password for UNATTENDED headless runs (npm run snipe + the
# auto-restart wrappers). Without it the headless runner prompts interactively.
# SECURITY TRADE-OFF: anyone who can read this file can unlock your key. Only
# use on a machine you control, with a throwaway wallet, and never commit .env.
# RH_PASSWORD=
